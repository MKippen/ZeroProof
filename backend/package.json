{
  "name": "zeroproof-backend",
  "version": "1.0.0",
  "description": "Backend for ZeroProof - UniFi Network Security Auditor",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scheduler": "node dist/scheduler.js",
    "test": "jest",
    "test:sandbox": "NODE_ENV=development jest -c jest.sandbox.config.js --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "doctor:stack": "tsx src/scripts/doctor-stack.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.17.3",
    "express-ws": "^5.0.2",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "mqtt": "^5.15.1",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/express-ws": "^3.0.4",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.19",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ],
    "overrides": {
      "ajv@<7": "6.15.0",
      "brace-expansion@<2": "1.1.14",
      "brace-expansion@>=2 <3": "2.1.0",
      "flatted": "3.4.2",
      "follow-redirects": "1.16.0",
      "minimatch@<4": "3.1.5",
      "minimatch@>=9 <10": "9.0.9",
      "path-to-regexp@<0.2": "0.1.13",
      "picomatch@<3": "2.3.2",
      "qs": "6.15.1"
    }
  }
}
