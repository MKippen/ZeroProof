# Absolute host path of this worktree. Required by docker-compose.yml so
# the updater container can mount the worktree at the same path inside
# itself — see HOST_WORKTREE comment in docker-compose.yml. install.sh
# writes this automatically; upgrade.sh backfills it on existing installs.
HOST_WORKTREE=/opt/zeroproof

# Database
POSTGRES_DB=zeroproof_dev
POSTGRES_PASSWORD=dev_password
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/zeroproof_dev

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=auditor
MQTT_PASSWORD=mqtt_password

# Backend
NODE_ENV=development
PORT=3000
SESSION_SECRET=dev-session-secret-change-me-32chars
ENCRYPTION_KEY=dev-encryption-key-32-bytes-minimum
DEFAULT_ADMIN_PASSWORD=admin123!

# Updater sidecar — shared HMAC secret for signed apply requests between
# backend and the updater container. Generated automatically by install.sh
# and dev-setup.sh on a fresh install. Leaving this blank disables in-app
# updates; CLI upgrade.sh still works.
UPDATER_SECRET=
# CORS_ORIGIN can be a comma-separated list (e.g. http://localhost:5173,http://127.0.0.1:5173)
# CORS_ORIGIN=
# HOST_IP is optional; set when running in Docker to advertise the server IP to devices
# HOST_IP=192.168.1.123

# Frontend
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000/ws
# VITE_SHOW_DEFAULT_CREDENTIALS=false
